# === AgentForge Configuration ===

# OpenRouter API Key (required) — get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-key-here

# OpenRouter base URL (default: https://openrouter.ai/api/v1)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model — any model available on OpenRouter
# Examples: google/gemini-2.0-flash-001, anthropic/claude-3.5-sonnet, openai/gpt-4o
MODEL_NAME=google/gemini-2.0-flash-001
TEMPERATURE=0.1

# Database
DB_PATH=data/agentforge.db

# ChromaDB
CHROMA_PERSIST_DIR=data/chroma_data
CHROMA_COLLECTION=agentforge_codebase

# === Security ===

# API Keys — comma-separated; leave empty to disable auth (dev mode)
API_KEYS=

# Rate limit — requests per minute per client IP; 0 = disabled
RATE_LIMIT_RPM=60

# Max code payload size in bytes (default: 512KB)
MAX_CODE_SIZE=524288

# CORS — comma-separated origins; * = allow all (dev mode)
CORS_ORIGINS=*

# === Logging ===
LOG_LEVEL=INFO

# === GitHub Integration ===

# GitHub personal access token (for posting review comments)
GITHUB_TOKEN=

# GitHub webhook secret (for verifying webhook signatures)
GITHUB_WEBHOOK_SECRET=
